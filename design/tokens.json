{
  "name": "Flint — Peak Focus",
  "description": "Single source of truth for Flint's brand + UI tokens. Consumed manually by ios-app (Asset Catalog / SwiftUI Color) and android-app (Compose Color/Theme). Keep platform themes in sync with this file.",
  "palette": {
    "flint":    { "hex": "#2C2C2A", "note": "charcoal base / dark surfaces / primary text on light" },
    "graphite": { "hex": "#5F5E5A", "note": "secondary text / muted UI" },
    "spark":    { "hex": "#EF9F27", "note": "PRIMARY ACCENT — the strike spark" },
    "ember":    { "hex": "#FAC775", "note": "light accent / highlights" },
    "bronze":   { "hex": "#BA7517", "note": "deep accent / pressed states" },
    "stone":    { "hex": "#F1EFE8", "note": "light surface / background" },
    "ash":      { "hex": "#B4B2A9", "note": "secondary text on dark" },
    "onAccent": { "hex": "#412402", "note": "text/icon color on spark/ember surfaces" }
  },
  "semantic": {
    "light": {
      "background":     "#F1EFE8",
      "surface":        "#FFFFFF",
      "surfaceVariant": "#E7E5DC",
      "surfaceContainerLowest":  "#FFFFFF",
      "surfaceContainerLow":     "#FAF9F4",
      "surfaceContainer":        "#F5F3EC",
      "surfaceContainerHigh":    "#E7E5DC",
      "surfaceContainerHighest": "#DDDBD0",
      "textPrimary":    "#2C2C2A",
      "textSecondary":  "#5F5E5A",
      "accent":         "#EF9F27",
      "accentPressed":  "#BA7517",
      "accentMuted":    "#FAC775",
      "onAccent":       "#412402",
      "selectedContainer":   "#FAC775",
      "onSelectedContainer": "#412402",
      "border":         "#D3D1C7",
      "borderVariant":  "#E0DED3",
      "danger":         "#C0392B",
      "dangerContainer":   "#F6DAD5",
      "onDangerContainer": "#6E1F16"
    },
    "dark": {
      "background":     "#2C2C2A",
      "surface":        "#3A3A37",
      "surfaceVariant": "#46453F",
      "surfaceContainerLowest":  "#262624",
      "surfaceContainerLow":     "#323230",
      "surfaceContainer":        "#3A3A37",
      "surfaceContainerHigh":    "#42423E",
      "surfaceContainerHighest": "#4A4A44",
      "textPrimary":    "#F1EFE8",
      "textSecondary":  "#B4B2A9",
      "accent":         "#EF9F27",
      "accentPressed":  "#BA7517",
      "accentMuted":    "#FAC775",
      "onAccent":       "#412402",
      "selectedContainer":   "#FAC775",
      "onSelectedContainer": "#412402",
      "border":         "#5F5E5A",
      "borderVariant":  "#514F49",
      "danger":         "#E07A6E",
      "dangerContainer":   "#5C2A23",
      "onDangerContainer": "#F3C1BA"
    }
  },
  "radius": { "sm": 8, "md": 12, "lg": 20, "pill": 999 },
  "spacing": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "gutter": 20, "cardGap": 12 },
  "typography": {
    "fontFamilySans": "system (SF Pro on iOS, Roboto/system on Android)",
    "fontFamilyMono": "system monospaced",
    "wordmark":  { "weight": 500, "letterSpacing": -1.0 },
    "title":     { "size": 28, "weight": 600 },
    "heading":   { "size": 20, "weight": 600 },
    "body":      { "size": 16, "weight": 400 },
    "caption":   { "size": 13, "weight": 400 },
    "label":     { "size": 11, "weight": 500, "letterSpacing": 0.7, "uppercase": true },
    "numerals":  { "note": "durations/counts use tabular figures (tnum) so timers never jitter" }
  },
  "motion": {
    "durationShortMs": 150,
    "durationMediumMs": 300,
    "durationLongMs": 450,
    "easingEmphasized": [0.2, 0, 0, 1],
    "easingStandard": [0.4, 0, 0.2, 1],
    "note": "one motion vocabulary app-wide: tab crossfades, editor push/pop, chart grow-in, block-screen breathing"
  }
}
