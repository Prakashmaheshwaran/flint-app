      "accentMuted":    "#FAC775",
      "onAccent":       "#412402",
      "border":         "#D3D1C7",
      "danger":         "#C0392B"
    },
    "dark": {
      "background":     "#2C2C2A",
      "surface":        "#3A3A37",
      "surfaceVariant": "#46453F",
      "textPrimary":    "#F1EFE8",
      "textSecondary":  "#B4B2A9",
      "accent":         "#EF9F27",
      "accentPressed":  "#BA7517",
      "accentMuted":    "#FAC775",
      "onAccent":       "#412402",
      "border":         "#5F5E5A",
      "danger":         "#E07A6E"
    }
  },
  "radius": { "sm": 8, "md": 12, "lg": 20, "pill": 999 },
