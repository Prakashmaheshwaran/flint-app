    "spark":    { "hex": "#EF9F27", "note": "PRIMARY ACCENT — the strike spark" },
    "ember":    { "hex": "#FAC775", "note": "light accent / highlights" },
    "bronze":   { "hex": "#BA7517", "note": "deep accent / pressed states" },
    "stone":    { "hex": "#F1EFE8", "note": "light surface / background" },
    "ash":      { "hex": "#B4B2A9", "note": "secondary text on dark" },
    "onAccent": { "hex": "#412402", "note": "text/icon color on spark/ember surfaces" }
  },
  "semantic": {
    "light": {
      "background":     "#F1EFE8",
      "surface":        "#FFFFFF",
      "surfaceVariant": "#E7E5DC",
      "textPrimary":    "#2C2C2A",
