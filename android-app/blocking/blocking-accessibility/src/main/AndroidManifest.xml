<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
          Flint's foreground-detection + URL-reading service.
          NOTE (Play policy): Flint is a "monitoring app" and is NOT eligible for
          isAccessibilityTool — so that flag is intentionally absent. The in-app prominent
          disclosure + affirmative consent (feature-onboarding) MUST precede enabling this.
        -->
        <service
            android:name=".FlintAccessibilityService"
            android:exported="false"
            android:label="@string/flint_a11y_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>
</manifest>
